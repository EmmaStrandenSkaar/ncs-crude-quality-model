{
  "metadata": {
    "title": "Crude assay enrichment for Norwegian Continental Shelf (NCS) blends",
    "compiled_date": "2026-06-12",
    "purpose": "Fluid quality enrichment for decline_quality analysis - link API/sulfur/TAN to field-level decline behavior",
    "notes": [
      "Crude Monitor (crudemonitor.ca) tracks ONLY Western Canadian crudes - NO Norwegian/North Sea coverage. Confirmed by direct fetch.",
      "Primary sources for NCS assays: Equinor crude oil assays page, ExxonMobil crude trading library, Oil & Gas Journal Guide to World Crudes, Energy Intelligence WCOD, TotalEnergies trading.",
      "Most NCS crudes are BLENDS commingled at export terminals (Mongstad, Sture, Teesside) - assay values represent the blend, not the individual field.",
      "Field-level assay (vs blend) is rarely public - need PDO documents or Sodir wellbore DST data for individual fields contributing to a blend.",
      "Where multiple sources disagree, values from the most recent OGJ Guide to World Crudes or Equinor publication are preferred."
    ],
    "sources": [
      "https://www.equinor.com/energy/crude-oil-assays (master table, updated through Mar 2026)",
      "https://www.crudemonitor.ca (confirmed Canada-only, no NCS coverage)",
      "https://corporate.exxonmobil.com/what-we-do/energy-supply/crude-trading/crude-oil-assays",
      "https://www.ogj.com (Oil & Gas Journal Guide to World Crudes series)",
      "https://www.energyintel.com/wcod (Energy Intelligence World Crude Oil Data)"
    ]
  },
  "crude_monitor_ca_coverage": {
    "url": "https://www.crudemonitor.ca",
    "norwegian_crudes_tracked": [],
    "note": "Crude Monitor explicitly limited to western Canadian crudes (Alberta/Saskatchewan). ~70+ grades including condensates, MSW feeders, light/medium/heavy sour, sweet synthetic, synbits. NO North Sea, NO NCS coverage."
  },
